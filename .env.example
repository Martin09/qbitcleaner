# qBittorrent Cleaner Configuration
# Copy this file to .env and edit with your settings.

# --- qBittorrent connection ---
QBIT_URL=https://your-qbittorrent-host:8080
QBIT_USERNAME=your-username
QBIT_PASSWORD=your-password

# SSL certificate verification (true/false)
# If not set, auto-detected from URL scheme (true for https, false for http)
# QBIT_VERIFY_SSL=false

# --- Cleanup criteria ---
# Minimum number of private torrents that must remain seeding
QBIT_MINIMUM_SEEDING_TORRENTS=15

# Minimum seeding time (days) before a torrent can be removed
QBIT_MINIMUM_SEEDING_TIME_DAYS=14

# --- Scheduling ---
# Cron expression for scheduled runs (leave empty or omit for single run)
# QBIT_SCHEDULE=0 0 * * *

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
QBIT_LOG_LEVEL=INFO

# Log file path (omit to log to stdout only)
# QBIT_LOG_FILE=qbitcleaner.log
